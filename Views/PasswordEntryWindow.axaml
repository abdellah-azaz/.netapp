<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MonAppMultiplateforme.Views.PasswordEntryWindow"
        Title="Authentification Requise"
        Width="400" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#f8fafc"
        Icon="/Assets/avalonia-logo.ico">

    <Border Padding="30">
        <StackPanel Spacing="20">
            <StackPanel Spacing="10">
                <TextBlock Text="🔒 Validation du Propriétaire" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="#2c3e50" HorizontalAlignment="Center"/>
                <TextBlock Text="Veuillez saisir votre mot de passe pour confirmer cette action sensible." 
                           FontSize="13" Foreground="#7f8c8d" 
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <TextBox Name="PasswordInput" 
                     PasswordChar="●" 
                     Watermark="Mot de passe"
                     Height="45"
                     VerticalContentAlignment="Center"
                     BorderBrush="#dfe6e9"
                     CornerRadius="8"/>

            <Grid ColumnDefinitions="*,* " HorizontalAlignment="Stretch" Margin="0,10,0,0">
                <Button Grid.Column="0" Content="Annuler" 
                        Click="OnCancelClick"
                        Background="#ecf0f1" Foreground="#7f8c8d" 
                        Padding="15,10" CornerRadius="8" 
                        HorizontalAlignment="Left"/>
                
                <Button Grid.Column="1" Content="Confirmer" 
                        Click="OnOkClick"
                        Background="#3498db" Foreground="White" 
                        FontWeight="Bold"
                        Padding="15,10" CornerRadius="8" 
                        HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </Border>

</Window>
